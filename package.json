{
  "name": "node-actuator-lite",
  "version": "3.1.1",
  "description": "Spring Boot Actuator for Node.js — health (shallow/deep), env, threaddump, heapdump, prometheus",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "test:package": "node tests/package-smoke.cjs",
    "audit:prod": "npm audit --omit=dev",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "actuator",
    "monitoring",
    "metrics",
    "prometheus",
    "health",
    "nodejs",
    "lightweight",
    "spring-boot",
    "serverless",
    "vercel",
    "lambda"
  ],
  "author": "Ankit Sharma <ankit.sharma199803@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/beingmartinbmc/node-actuator-lite.git"
  },
  "bugs": {
    "url": "https://github.com/beingmartinbmc/node-actuator-lite/issues"
  },
  "homepage": "https://github.com/beingmartinbmc/node-actuator-lite#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware/express": {
      "types": "./dist/middleware/express.d.ts",
      "require": "./dist/middleware/express.js",
      "default": "./dist/middleware/express.js"
    },
    "./middleware/fastify": {
      "types": "./dist/middleware/fastify.d.ts",
      "require": "./dist/middleware/fastify.js",
      "default": "./dist/middleware/fastify.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "USAGE.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "examples/**/*",
    "LICENSE"
  ],
  "dependencies": {
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
